# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Credentials (OPTIONAL - Leave empty to use Application Default Credentials)
# For local dev: Run `gcloud auth application-default login` instead of using a JSON file
# For Cloud Run: Automatically uses the service account (no file needed)
# Only uncomment the line below if you have a service account key JSON file
# FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# WhatsApp Business API Configuration
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Google Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key

# Frontend URL (for CORS and check-in links)
FRONTEND_URL=http://localhost:3000

# Check-in Settings
CHECK_IN_TOKEN_EXPIRY_MINUTES=30
GEOLOCATION_RADIUS_METERS=100
REMINDER_MINUTES_BEFORE=10

# JWT Settings
JWT_EXPIRY_HOURS=24
